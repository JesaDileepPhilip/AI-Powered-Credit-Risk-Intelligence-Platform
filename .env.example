# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Environment variable template
#
# Copy this file to .env and fill in your values.
# The .env file MUST NOT be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Credit Risk Intelligence Platform"
APP_VERSION="1.0.0"

# ── Logging ───────────────────────────────────────────────────────────────────
# Accepted values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ── EDA Settings ──────────────────────────────────────────────────────────────
# Leave EDA_SAMPLE_SIZE blank to use the full dataset (recommended for final runs)
EDA_SAMPLE_SIZE=
EDA_FIGURE_DPI=150
EDA_CORRELATION_TOP_N=30
EDA_FIGURE_STYLE=darkgrid
EDA_OUTLIER_CAP_PERCENTILE=0.99

# ── ML Settings ───────────────────────────────────────────────────────────────
RANDOM_SEED=42
TEST_SIZE=0.2
CV_FOLDS=5

# ── Database ──────────────────────────────────────────────────────────────────
# Relative or absolute path to the SQLite database file
DB_PATH=data/credit_risk.db
DB_ECHO_SQL=false

# ── LLM / Chatbot ─────────────────────────────────────────────────────────────
# Provider-agnostic OpenAI-compatible configuration.
# Works with: OpenAI, Azure OpenAI, Together AI, Groq, Ollama, LM Studio, etc.
#
# OpenAI (default):
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=1024
#
# Azure OpenAI example:
# OPENAI_BASE_URL=https://<your-resource>.openai.azure.com/openai/deployments/<deployment>/
# OPENAI_MODEL=gpt-4o
#
# Together AI example:
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
#
# Groq example:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama3-70b-8192
#
# Ollama (local) example:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3
#
# LM Studio (local) example:
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=local-model
